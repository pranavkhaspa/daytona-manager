{
  "name": "@daytona/sdk",
  "version": "0.193.0",
  "description": "Daytona TypeScript SDK for sandbox management and code execution",
  "exports": {
    ".": {
      "import": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      },
      "require": {
        "types": "./cjs/index.d.ts",
        "default": "./cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "browser": {
    "module": false,
    "fs": false,
    "stream": false,
    "crypto": false,
    "buffer": false,
    "tar": false,
    "fast-glob": false,
    "expand-tilde": false,
    "@iarna/toml": false,
    "form-data": false,
    "busboy": false,
    "@aws-sdk/client-s3": false,
    "@aws-sdk/lib-storage": false,
    "@opentelemetry/sdk-node": false,
    "@opentelemetry/instrumentation-http": false,
    "@opentelemetry/sdk-trace-base": false,
    "@opentelemetry/exporter-trace-otlp-http": false,
    "@opentelemetry/otlp-exporter-base": false,
    "@opentelemetry/semantic-conventions": false,
    "@opentelemetry/resources": false
  },
  "files": [
    "esm",
    "cjs",
    "!**/__tests__",
    "!**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daytona/clients.git"
  },
  "author": "Daytona Platforms Inc.",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/daytona/clients/issues"
  },
  "homepage": "https://www.daytona.io/docs",
  "config": {
    "docsDir": "../artifacts/sdk-docs/typescript-sdk"
  },
  "scripts": {
    "docs": "bash -O extglob -c 'rm -rf $npm_package_config_docsDir/!(index.mdx)' && typedoc && rm -f $npm_package_config_docsDir/readme.mdx"
  },
  "keywords": [
    "daytona",
    "sandbox",
    "typescript",
    "sdk"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/lib-storage": "^3.798.0",
    "@iarna/toml": "^2.2.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation-http": "^0.217.0",
    "@opentelemetry/otlp-exporter-base": "0.217.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "axios": "^1.15.2",
    "busboy": "^1.0.0",
    "dotenv": "^17.0.1",
    "expand-tilde": "^2.0.2",
    "fast-glob": "^3.3.0",
    "form-data": "^4.0.4",
    "isomorphic-ws": "^5.0.0",
    "pathe": "^2.0.3",
    "shell-quote": "^1.8.2",
    "tar": "^7.5.11",
    "@daytona/api-client": "0.193.0",
    "@daytona/toolbox-api-client": "0.193.0"
  }
}